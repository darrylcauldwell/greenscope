# GreenScope Configuration
# Copy to .env and adjust values for your environment

# Prometheus
GREENSCOPE_PROMETHEUS_URL=http://greenscope-prometheus:9090/prometheus

# UK Carbon Intensity API
GREENSCOPE_CARBON_INTENSITY_API_URL=https://api.carbonintensity.org.uk/intensity
GREENSCOPE_CARBON_INTENSITY_FALLBACK=230.0

# Host hardware configuration
GREENSCOPE_HOST_TDP_WATTS=205
GREENSCOPE_HOST_CORES=2
GREENSCOPE_HOST_PUE=1.2
GREENSCOPE_HOST_EMBODIED_CO2_KG=1205.52
GREENSCOPE_HOST_LIFESPAN_YEARS=4

# App boundaries — JSON mapping app name to list of container names
GREENSCOPE_APP_BOUNDARIES={"evm": ["evm-backend", "evm-frontend", "evm-db"], "equicalendar": ["compgather"], "meweb": ["caddy"]}

# App request jobs — JSON mapping app name to Prometheus job name
GREENSCOPE_APP_REQUEST_JOBS={"evm": "evm-backend", "equicalendar": "compgather", "meweb": "caddy"}

# Calculation interval in minutes
GREENSCOPE_CALCULATION_INTERVAL_MINUTES=15

# Database
GREENSCOPE_DATABASE_URL=sqlite+aiosqlite:///data/greenscope.db

# Logging
GREENSCOPE_LOG_LEVEL=INFO
